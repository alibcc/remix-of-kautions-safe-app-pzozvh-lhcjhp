
{
  "expo": {
    "name": "Kautions-Safe",
    "slug": "Kautions-Safe",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-xdh.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/app-icon-xdh.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Natively",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Kautions-Safe möchte auf Ihre Kamera zugreifen, um Fotos für das Protokoll zu machen.",
        "NSPhotoLibraryUsageDescription": "Kautions-Safe möchte auf Ihre Fotos zugreifen, um Bilder für das Protokoll auszuwählen."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-xdh.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.Natively",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Kautions-Safe möchte auf Ihre Kamera zugreifen, um Fotos für das Protokoll zu machen."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Kautions-Safe möchte auf Ihre Fotos zugreifen, um Bilder für das Protokoll auszuwählen.",
          "cameraPermission": "Kautions-Safe möchte auf Ihre Kamera zugreifen, um Fotos für das Protokoll zu machen."
        }
      ]
    ],
    "scheme": "kautions-safe",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://rtcsrhamfbtmv77fdyw7wqbktr6af39m.app.specular.dev"
    }
  }
}
