{
  "expo": {
    "name": "Kautions-Safe",
    "slug": "Kautions-Safe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-xdh.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/app-icon-xdh.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Natively",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-xdh.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.Natively"
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to document apartment defects.",
          "cameraPermission": "The app needs access to your camera to take photos of apartment defects and utility meters."
        }
      ]
    ],
    "scheme": "Kautions-Safe",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://rtcsrhamfbtmv77fdyw7wqbktr6af39m.app.specular.dev"
    }
  }
}