{
  "expo": {
    "name": "MoveProof",
    "slug": "moveproof",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/moveproof_icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/moveproof_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alibcc.moveproof",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "MoveProof möchte auf Ihre Kamera zugreifen, um Fotos für das Protokoll zu machen.",
        "NSPhotoLibraryUsageDescription": "MoveProof möchte auf Ihre Fotos zugreifen, um Bilder für das Protokoll auszuwählen.",
        "NSLocationWhenInUseUsageDescription": "MoveProof uses your location to help identify your property address."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/moveproof_icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.moveproof.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
